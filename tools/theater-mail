#!/usr/bin/env python3
"""theater-mail — MH mailbox backend for tools/theater mail commands.

Internal module called by tools/theater. Not invoked directly by actors.

Uses Python's mailbox.MH for proper message storage with:
- Deduplication via From|Subject|Date keys
- .mh_sequences tracking read/unread (unseen) state
- Peer-to-peer delivery during sync (reads sender's outbox from workspace checkout)
"""

import email
import email.message
import mailbox
import sys
from datetime import datetime, timezone
from pathlib import Path

ACTORS = sorted(
    p.parent.name
    for p in Path("backstage").glob("*/SOUL.md")
    if p.parent.name != "_template"
)
REPO = "franklinbaldo/the-theater"
SESSION_FILE = ".theater_session"


def whoami():
    """Read logged-in actor from .theater_session (written by tools/theater login)."""
    p = Path(SESSION_FILE)
    if not p.exists():
        return None
    return p.read_text(encoding="utf-8").strip() or None


def today():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")


def get_mh(actor, box="inbox"):
    """Get or create an MH mailbox for an actor."""
    path = Path(f"backstage/{actor}/mail/{box}")
    path.mkdir(parents=True, exist_ok=True)
    return mailbox.MH(str(path), create=True)


def dedup_key(msg):
    """Create a deduplication key from message headers."""
    return f"{msg.get('From', '')}|{msg.get('Subject', '')}|{msg.get('Date', '')}"


# ── Actor commands ───────────────────────────────────────────────────────────


def cmd_list(me, _args):
    """List inbox messages with unseen markers."""

    inbox = get_mh(me, "inbox")
    keys = inbox.keys()

    if not keys:
        print(f"Inbox empty (backstage/{me}/mail/inbox/)")
        inbox.close()
        return

    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))

    print(f"=== Inbox for {me} ({len(keys)} messages, {len(unseen)} unseen) ===\n")
    for key in sorted(keys):
        msg = inbox[key]
        marker = " *" if key in unseen else "  "
        sender = msg.get("From", "?")
        subject = msg.get("Subject", "(no subject)")
        date = msg.get("X-Theater-Date", msg.get("Date", "?"))
        replied = key in set(sequences.get("replied", []))
        r_marker = " [replied]" if replied else ""
        print(f"  {marker} #{key}  {sender:15s}  {subject}{r_marker}")

    inbox.close()
    print(f"\nRead: tools/theater mail read <number>")


def cmd_read(me, args):
    """Read a message and mark as seen."""

    if not args:
        print("Usage: theater-mail read <message-number>")
        sys.exit(1)

    try:
        key = int(args[0])
    except ValueError:
        print(f"ERROR: '{args[0]}' is not a valid message number.")
        sys.exit(1)

    inbox = get_mh(me, "inbox")
    try:
        msg = inbox[key]
    except KeyError:
        print(f"ERROR: No message #{key} in inbox.")
        inbox.close()
        sys.exit(1)

    # Display
    print(f"From: {msg.get('From', '?')}")
    print(f"To: {msg.get('To', '?')}")
    print(f"Subject: {msg.get('Subject', '?')}")
    print(f"Date: {msg.get('Date', '?')}")
    print("---")
    print(msg.get_payload())

    # Mark as seen (remove from unseen sequence)
    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))
    if key in unseen:
        unseen.discard(key)
        sequences["unseen"] = sorted(unseen)
        inbox.set_sequences(sequences)

    inbox.flush()
    inbox.close()


def cmd_status(me, _args):
    """Show inbox/outbox summary."""

    inbox = get_mh(me, "inbox")
    outbox = get_mh(me, "outbox")

    inbox_keys = inbox.keys()
    outbox_keys = outbox.keys()
    sequences = inbox.get_sequences()
    unseen = len(sequences.get("unseen", []))

    print(f"=== Mail for {me} ===")
    print(f"  Inbox:  {len(inbox_keys)} ({unseen} unseen)")
    print(f"  Outbox: {len(outbox_keys)} queued")

    if unseen > 0:
        print(f"\n  Unseen:")
        for key in sequences.get("unseen", [])[:5]:
            msg = inbox[key]
            print(f"    #{key} from {msg.get('From', '?')}: {msg.get('Subject', '?')}")

    inbox.close()
    outbox.close()


# ── Mail delivery (from workspace checkouts) ─────────────────────────────────

def cmd_deliver(args):
    """Deliver mail from workspace checkouts to the current actor's inbox.

    Called by `tools/theater sync` after cloning branches into workspace/.
    Reads outbox files directly from workspace/{sender}/backstage/{sender}/mail/outbox/.
    Prints the number of delivered messages to stdout (for the shell caller).
    """
    if not args:
        print("0")
        return

    me = args[0]
    workspace = Path("workspace")
    total = 0

    inbox = get_mh(me, "inbox")
    existing_keys = set()
    for k in inbox.keys():
        existing_keys.add(dedup_key(inbox[k]))

    for sender_dir in sorted(workspace.iterdir()):
        if not sender_dir.is_dir():
            continue
        sender = sender_dir.name
        if sender == me or sender not in ACTORS:
            continue

        outbox_path = sender_dir / "backstage" / sender / "mail" / "outbox"
        if not outbox_path.is_dir():
            continue

        for msg_file in sorted(outbox_path.iterdir()):
            if msg_file.name.startswith(".") or not msg_file.is_file():
                continue

            try:
                content = msg_file.read_text(encoding="utf-8", errors="replace")
            except Exception:
                continue

            # Try to parse as email message first
            try:
                msg = email.message_from_string(content)
            except Exception:
                continue

            # Check if addressed to us
            recipient = msg.get("To", "")
            if recipient != me:
                # Also check filename pattern TO_{recipient}_...
                if not msg_file.name.startswith(f"TO_{me}_"):
                    continue

            msg_key = dedup_key(msg)
            if msg_key in existing_keys:
                continue

            # Deliver
            safe_content = content.encode("ascii", "replace").decode("ascii")
            mh_msg = mailbox.MHMessage(safe_content)
            new_key = inbox.add(mh_msg)

            sequences = inbox.get_sequences()
            unseen = list(sequences.get("unseen", []))
            unseen.append(new_key)
            sequences["unseen"] = sorted(unseen)
            inbox.set_sequences(sequences)

            existing_keys.add(msg_key)
            total += 1

    inbox.flush()
    inbox.close()
    print(total)


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print("Usage: tools/theater mail [list|read <num>|status|deliver <actor>]")
        sys.exit(1)

    cmd = sys.argv[1]

    # 'deliver' reads from workspace/ checkouts (called by tools/theater sync)
    if cmd == "deliver":
        cmd_deliver(sys.argv[2:])
        return

    actor_commands = {
        "list": cmd_list,
        "read": cmd_read,
        "status": cmd_status,
    }

    if cmd not in actor_commands:
        print(f"Unknown mail command: {cmd}")
        print(f"Available: {', '.join(actor_commands)}, deliver")
        sys.exit(1)

    me = whoami()
    if not me:
        print("ERROR: Not logged in. Run: tools/theater login <your-actor>")
        sys.exit(1)

    actor_commands[cmd](me, sys.argv[2:])


if __name__ == "__main__":
    main()
