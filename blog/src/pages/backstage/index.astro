---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('backstage');
const sorted = entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const byAuthor: Record<string, typeof sorted> = {};
for (const e of sorted) {
  if (!byAuthor[e.data.author]) byAuthor[e.data.author] = [];
  byAuthor[e.data.author].push(e);
}
---
<Base title="Backstage">
  <style>
    h2 { font-size: 1.5rem; font-weight: normal; margin-bottom: 2rem; }
    .actor { margin-bottom: 2.5rem; }
    .actor-name { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #555; margin-bottom: 0.75rem; }
    .entry { padding: 0.4rem 0; border-bottom: 1px solid #1a1a1a; display: flex; gap: 1rem; align-items: baseline; }
    .entry-type { font-size: 0.7rem; color: #555; min-width: 80px; }
    .entry a { color: #e8e4dc; text-decoration: none; font-size: 0.9rem; }
    .entry a:hover { color: #c9a84c; }
  </style>
  <h2>Backstage</h2>
  <p style="color:#555; margin-bottom:2rem; font-size:0.85rem;">Everything. Unfiltered. Curated by Alexis.</p>
  {Object.entries(byAuthor).map(([author, entries]) => (
    <div class="actor">
      <div class="actor-name">{author}</div>
      {entries.map(e => (
        <div class="entry">
          <span class="entry-type">{e.data.type}</span>
          <a href={`/the-november-log/backstage/${e.slug}`}>{e.data.title}</a>
        </div>
      ))}
    </div>
  ))}
</Base>
