---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const backstage = await getCollection('backstage');

const all = [...posts, ...backstage].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const press = all.filter(e => e.data.type === 'post' || e.data.type === 'interview');
---
<Base title="Press Coverage">
  <style>
    .intro { margin-bottom: 3rem; text-align: center; border-bottom: 2px solid #2a2a2a; padding-bottom: 2rem; }
    .intro h2 { font-size: 3rem; margin-bottom: 0.5rem; font-weight: normal; letter-spacing: 0.05em; text-transform: uppercase; }
    .intro p { color: #888; max-width: 600px; margin: 0 auto; font-style: italic; }

    .press-list { display: flex; flex-direction: column; gap: 2rem; }
    .press-item { border-bottom: 1px solid #1a1a1a; padding-bottom: 2rem; }
    .press-item:last-child { border-bottom: none; }
    .press-item .meta { font-size: 0.85rem; margin-bottom: 0.5rem; display: flex; gap: 1rem; text-transform: uppercase; letter-spacing: 0.05em; align-items: center; }
    .press-item .type-badge { font-size: 0.7rem; padding: 0.2rem 0.5rem; background: #222; color: #7eb8a0; border-radius: 3px; }
    .press-item .date { color: #888; }
    .press-item .author { color: #888; }
    .press-item h3 { font-size: 1.5rem; font-weight: normal; margin-bottom: 0.5rem; }
    .press-item h3.interview { font-style: italic; }
    .press-item h3 a { color: #e8e4dc; text-decoration: none; }
    .press-item h3 a:hover { color: #7eb8a0; }
    .press-item .read-more { font-size: 0.85rem; color: #7eb8a0; text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; display: inline-block; margin-top: 0.5rem; }
    .press-item .read-more:hover { color: #e8e4dc; }
  </style>

  <div class="intro">
    <h2>Alexis Coverage</h2>
    <p>Posts, explainers, and interviews. Alexis is the public voice of the theater.</p>
  </div>

  <div class="press-list">
    {press.map(item => (
      <div class="press-item">
        <div class="meta">
          <span class="type-badge">{item.data.type === 'post' ? 'Post' : 'Interview'}</span>
          <span class="date">{item.data.date}</span>
          <span class="author">@{item.data.author}</span>
        </div>
        <h3 class={item.data.type === 'interview' ? 'interview' : ''}>
          <a href={`/the-theater/${item.collection}/${item.id}`}>
            {item.data.type === 'interview' ? `"${item.data.title}"` : item.data.title}
          </a>
        </h3>
        <a href={`/the-theater/${item.collection}/${item.id}`} class="read-more">Read →</a>
      </div>
    ))}
  </div>
</Base>
