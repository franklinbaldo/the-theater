---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const backstage = await getCollection('backstage');

const all = [...posts, ...backstage].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const scenes = all.filter(e => e.data.type === 'scene');
---
<Base title="Scenes">
  <style>
    .intro { margin-bottom: 3rem; text-align: center; border-bottom: 2px solid #2a2a2a; padding-bottom: 2rem; }
    .intro h2 { font-size: 3rem; margin-bottom: 0.5rem; font-weight: normal; letter-spacing: 0.05em; text-transform: uppercase; }
    .intro p { color: #888; max-width: 600px; margin: 0 auto; font-style: italic; }

    .scene-list { display: flex; flex-direction: column; gap: 2rem; }
    .scene-item { border-bottom: 1px solid #1a1a1a; padding-bottom: 2rem; }
    .scene-item:last-child { border-bottom: none; }
    .scene-item .meta { font-size: 0.85rem; color: #888; margin-bottom: 0.5rem; display: flex; gap: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .scene-item h3 { font-size: 1.75rem; font-weight: normal; margin-bottom: 0.5rem; }
    .scene-item h3 a { color: #e8e4dc; text-decoration: none; }
    .scene-item h3 a:hover { color: #c9a84c; }
    .scene-item .excerpt { font-size: 1rem; color: #aaa; margin-bottom: 1rem; line-height: 1.6; }
    .scene-item .read-more { font-size: 0.85rem; color: #c9a84c; text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; }
    .scene-item .read-more:hover { color: #e8e4dc; }
  </style>

  <div class="intro">
    <h2>Scenes</h2>
    <p>The story as it unfolds. Written by Franklin, performed by the cast.</p>
  </div>

  <div class="scene-list">
    {scenes.map(scene => (
      <div class="scene-item">
        <div class="meta">
          <span>{scene.data.date}</span>
          {scene.data.session && <span>Session {scene.data.session}</span>}
          <span>By {scene.data.author}</span>
        </div>
        <h3>
          <a href={`/the-theater/${scene.collection}/${scene.id}`}>
            {scene.data.title}
          </a>
        </h3>
        <div class="excerpt">
          {scene.body ? scene.body.substring(0, 300).replace(/[#*]/g, '') + '...' : ''}
        </div>
        <a href={`/the-theater/${scene.collection}/${scene.id}`} class="read-more">Read Scene →</a>
      </div>
    ))}
  </div>
</Base>
